# ===========================================================================
# PLATAFORMA DE TUTORES PERSONALIZADOS — CONFIGURAÇÃO DE AMBIENTE (EXEMPLO)
# ===========================================================================
# IMPORTANTE: Clone este arquivo para um arquivo chamado '.env' localmente
# e preencha com as suas chaves reais. O arquivo '.env' está listado no
# .gitignore e NUNCA deve ser commitado para produção.

# 1. Configuração do Modelo do Agente (Pydantic AI)
# Para homologação sem custos/chaves, utilize "test" (ativa o TestModel nativo).
# Em produção, use o formato "provedor:modelo" (ex: "openai:gpt-4o-mini", "anthropic:claude-3-5-sonnet")
AGENT_MODEL=test

# 2. Segurança e Controle de Acesso Administrativo
# Chave mestra estática validada no header X-Admin-API-Key para o CRUD de tutores
ADMIN_API_KEY=dev-only-change-me-in-producao

# 3. Persistência de Dados (SQLite local)
# Caminho absoluto ou relativo para o arquivo do banco de dados local
DATABASE_FILE=data/tutores.db

# 4. Provedores Comerciais de LLM (Descomente se AGENT_MODEL for diferente de "test")
# O Pydantic AI lerá estas variáveis automaticamente do ambiente do sistema.
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIzaSy...
